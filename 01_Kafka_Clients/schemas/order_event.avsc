{
  "type": "record",
  "name": "OrderEvent",
  "namespace": "com.masterclass.kafka",
  "fields": [
    {"name": "order_id", "type": "string"},
    {"name": "customer_id", "type": "string"},
    {"name": "status", "type": "string"},
    {"name": "amount_cents", "type": "long"},
    {"name": "currency", "type": "string", "default": "USD"},
    {"name": "event_time", "type": "long"}
  ]
}
